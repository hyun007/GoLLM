# LLM endpoint (llama.cpp or any OpenAI-compatible server)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=llama3          # model name sent in requests (llama.cpp ignores this)
LLM_API_KEY=none          # set if your endpoint requires an API key

# =============================================================================
# Option A: GoTTY web console (binhex/arch-minecraftserver default port 8222)
# Single WebSocket handles both commands AND log watching — no RCON needed.
# =============================================================================
GOTTY_HOST=192.168.1.3
GOTTY_PORT=8222
GOTTY_USER=admin
GOTTY_PASSWORD=your_gotty_password_here

# =============================================================================
# Option B: RCON + SSH/local log (used when GOTTY_HOST is not set)
# Requires rcon.port to be published in docker-compose and enabled in server.properties.
# =============================================================================

# Minecraft server RCON
# RCON_HOST=your-server.example.com
# RCON_PORT=25575
# RCON_PASSWORD=your_rcon_password_here

# Chatbot log source: 'docker' or 'local'
# LOG_MODE=docker

# --- Docker mode (SSH to Docker host, stream container logs) ---
# DOCKER_CONTAINER=binhex-minecraftserver
# SSH_HOST=your-server.example.com
# SSH_PORT=22
# SSH_USER=ubuntu
# SSH_KEY_PATH=/home/youruser/.ssh/id_rsa
# SSH_PASSWORD=secret   # alternative to key auth

# --- Local mode ---
# LOG_MODE=local
# LOG_PATH=/opt/minecraft/logs/latest.log

# Autonomous mode tick interval in milliseconds
AUTONOMOUS_INTERVAL=60000
